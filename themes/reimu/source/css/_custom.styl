.moment-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  position: relative;
}

.moment-content,
.moments-content {
  white-space: pre-line;
}

.moments-meta {
  position: absolute;
  right: 16px;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  font-size: 12px;
  color: #888;
}

.moments-location {
  margin-bottom: 2px;
  font-weight: 500;
  position: relative;
  top: -1px;
  opacity: 0.8;
}

.moments-time {
  opacity: 0.8;
}
