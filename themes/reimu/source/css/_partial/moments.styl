.moments-wrap
  max-width 800px
  margin 0 auto
  padding 20px
 
.moments-item
  background var(--card-bg)
  border-radius 12px
  padding 20px
  margin-bottom 20px
  box-shadow 0 2px 12px rgba(0,0,0,0.1)
  transition transform 0.3s ease, box-shadow 0.3s ease
  
  &:hover
    transform translateY(-2px)
    box-shadow 0 4px 20px rgba(0,0,0,0.15)
 
.moments-content
  position relative
 
.moments-text
  font-size 16px
  line-height 1.6
  color var(--text-color)
  margin-bottom 15px
  word-wrap break-word
 
.moments-images
  display grid
  grid-template-columns repeat(auto-fit, minmax(150px, 1fr))
  gap 8px
  margin 15px 0
 
.moments-image
  width 100%
  height 150px
  object-fit cover
  border-radius 8px
  cursor pointer
  transition transform 0.3s ease
  
  &:hover
    transform scale(1.05)
 
.moments-location
  font-size 14px
  color var(--text-color-3)
  margin 10px 0
  display flex
  align-items center
  
  .icon-location
    margin-right 5px
 
.moments-meta
  display flex
  justify-content flex-end
  align-items center
  margin-top 15px
  padding-top 15px
  border-top 1px solid var(--border-color)
 
.moments-time
  font-size 13px
  color var(--text-color-3)
  font-family monospace
 
// 响应式设计
@media (max-width: 768px)
  .moments-wrap
    padding 15px
    
  .moments-item
    padding 15px
    
  .moments-images
    grid-template-columns repeat(auto-fit, minmax(100px, 1fr))
    
  .moments-image
    height 100px



// 点赞和评论交互样式
.moments-interaction
  display flex
  gap 20px
  margin 15px 0
  padding 15px 0
  border-top 1px solid var(--border-color)
  border-bottom 1px solid var(--border-color)
 
.moments-likes, .moments-comments
  display flex
  align-items center
  gap 8px
  cursor pointer
  transition all 0.3s ease
  color var(--text-color-3)
  font-size 14px
  user-select none
  
  &:hover
    color var(--red-1)
    transform scale(1.05)
    
  .icon-heart, .icon-comment
    font-size 16px
    transition all 0.3s ease
    
  .likes-count, .comments-count
    font-weight 500
    min-width 20px
    text-align center
 
.moments-likes
  &.liked
    color var(--red-1)
    
    .icon-heart
      color var(--red-1)
      animation heartBeat 0.6s ease-in-out
 
// 心跳动画
@keyframes heartBeat
  0%
    transform scale(1)
  25%
    transform scale(1.3)
  50%
    transform scale(1)
  75%
    transform scale(1.3)
  100%
    transform scale(1)
 
// 提示框样式
.toast-notification
  backdrop-filter blur(10px)
  background rgba(255, 255, 255, 0.9)
  border 1px solid rgba(0, 0, 0, 0.1)
 
@media (prefers-color-scheme: dark)
  .toast-notification
    background rgba(0, 0, 0, 0.8)
    color #fff

