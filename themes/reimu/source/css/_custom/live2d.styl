/* ===== Live2D 对话气泡终极覆盖（100% 生效版） ===== */
html body div#live2d-tips,
html body div#live2d-tips.live2d-tips,
html body div#live2d-tips.live2d-tips-active {
  color: #B22222 !important;                              /* 深红文字 */
  font-weight: 700 !important;                            /* 加粗 */
  font-size: 14px !important;                             /* 字号 */
  text-shadow: 1px 1px 2px #000000 !important;            /* 黑色阴影 */
  background-color: rgba(255, 255, 255, 0.95) !important; /* 白色半透明背景 */
  background-image: none !important;                      /* 清除主题背景 */
  border: 1px solid #B22222 !important;                   /* 红色边框 */
  border-radius: 10px !important;                         /* 圆角 */
  padding: 8px 12px !important;                           /* 内边距 */
  max-width: 250px !important;                            /* 最大宽度 */
  word-break: break-word !important;                      /* 自动换行 */
  opacity: 1 !important;                                  /* 不透明 */
  z-index: 9999 !important;                               /* 顶层 */
}